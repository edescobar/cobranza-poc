# --- serving (needed to run the app) ---
POSTGRES_PASSWORD=change-me
OLLAMA_MODEL=qwen2.5:3b         # instruct model, no reasoning mode → fast direct answers.
                                # bake-off options: qwen2.5:7b (better Spanish), qwen2.5:1.5b (fastest).
                                # NOT qwen3 — it reasons out loud even with think:false, killing latency.

# --- pipeline (only needed to ingest real calls) ---
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=

# S3 where the historical human-call audio lives
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# --- exposure (only needed for the Cloudflare tunnel) ---
TUNNEL_TOKEN=

# how the pipeline reaches Postgres from the host
DATABASE_URL=postgresql://cobranza:change-me@localhost:5432/cobranza
